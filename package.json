{
  "name": "@flowness-labs/monorepo",
  "private": true,
  "version": "0.2.5",
  "description": "Flowness monorepo scaffold and CLI workspace.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "npm run build && node --test $(find packages -path '*/dist/*.test.js' | sort)",
    "audit": "node scripts/audit-v0.1.mjs",
    "release:docs-check": "node scripts/release-docs-check.mjs",
    "release:check": "node scripts/release-check.mjs",
    "typecheck": "tsc -b --pretty false",
    "link:cli": "npm run build && npm link --force --workspace packages/cli"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "author": "bhoon716",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bhoon716/flowness.git"
  },
  "bugs": {
    "url": "https://github.com/bhoon716/flowness/issues"
  },
  "homepage": "https://github.com/bhoon716/flowness#readme"
}
