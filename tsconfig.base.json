{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@flowness-labs/core": [
        "packages/core/src/index.ts"
      ],
      "@flowness-labs/config-system": [
        "packages/config-system/src/index.ts"
      ],
      "@flowness-labs/decision-system": [
        "packages/decision-system/src/index.ts"
      ],
      "@flowness-labs/evidence-system": [
        "packages/evidence-system/src/index.ts"
      ],
      "@flowness-labs/issue-system": [
        "packages/issue-system/src/index.ts"
      ],
      "@flowness-labs/log-system": [
        "packages/log-system/src/index.ts"
      ],
      "@flowness-labs/review-system": [
        "packages/review-system/src/index.ts"
      ],
      "@flowness-labs/templates": [
        "packages/templates/src/index.ts"
      ],
      "@flowness-labs/workflow-engine": [
        "packages/workflow-engine/src/index.ts"
      ],
      "@flowness-labs/cli": [
        "packages/cli/src/index.ts"
      ]
    }
  }
}

